{
  "pre_registration": {
    "go_threshold": 2,
    "minimum_corpus_n": 8,
    "trials_per_arm": 3,
    "arm_c_context_rule": "doc text + CLAUDE.md + AGENTS.md + cited files"
  },
  "arms": ["a_baseline", "b_isolated", "c_fixed_context", "d_self_critic"],
  "docs": [
    { "id": "kf-1", "path": "docs/plans/example-a.md", "subset": "known_failure", "issue_that_mattered": "x" },
    { "id": "fr-1", "path": "docs/plans/example-b.md", "subset": "forward_rated" }
  ]
}
